# ============================================================
# ZenBoard — 环境变量（仓库根目录）
# 复制为 .env 后填写：cp .env.example .env
# .env 已加入根目录 .gitignore，不会提交
# ============================================================

# ---- 后端（go run / Docker backend 共用键名）----
PORT=8080

# 本地开发：连本机 Postgres / Redis；Docker Compose 会在 compose 里覆盖为 postgres / redis 主机名
PG_DSN=host=localhost user=zenboard password=zenboard123 dbname=zenboard port=5432 sslmode=disable TimeZone=Asia/Shanghai
REDIS_ADDR=localhost:6379

ADMIN_USER=admin
ADMIN_PASS=change_me_in_production
JWT_SECRET=a-very-long-random-secret-string-change-me

# ---- 禅道 MySQL（只读；也可在前端「系统配置」填写）----
ZT_HOST=
ZT_PORT=3306
ZT_USER=
ZT_PASS=
ZT_DBNAME=zentao

# ---- ETL ----
ETL_CONFIG_PATH=config/etl_tables.yaml
# 自动同步周期间隔（分钟），仅作默认值；启动后可在「系统配置」页覆盖并写入数据库
# SYNC_INTERVAL_MINUTES=15

# ---- Docker Compose 端口（可选；未设置则用 compose 内默认值）----
# WEB_PORT=80          # 前端 Nginx；无 root 权限时可改为 8080
# BACKEND_PUBLISH=8080
# POSTGRES_PUBLISH=5432
# REDIS_PUBLISH=6379

