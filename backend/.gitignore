# =========================================================================
# 后端 (Go) 忽略规则
# =========================================================================

# 真实环境变量（包含数据库密码）
.env
.env.*
!.env.example

# Go 构建产物
/bin/
*.exe
*.test
*.prof

# 测试缓存
/tmp/

# 依赖包缓存
vendor/
go.work
go.work.sum

# IDE
.idea/
.vscode/
